{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "FileStorage": {
    "UploadPath": "wwwroot/uploads",
    "ProductImagesPath": "products",
    "MaxFileSize": 5242880,
    "AllowedExtensions": [ "image/jpeg", "image/png", "image/webp" ]
  },
  "Cors": {
    "AllowedOrigins": ["https://localhost:3000"]
  },
  "Frontend": {
    "BaseUrl": "https://localhost:3000"
  },
  "AllowedHosts": "*"
}
